# URL Publique
ROOT_URL=https://your-domain.com

# MongoDB - ⚠️ CHANGEZ CES VALEURS EN PRODUCTION
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=CHANGEME_STRONG_PASSWORD_HERE
MONGO_DATABASE=rocketchat

# Admin Rocket.Chat - ⚠️ CHANGEZ CES VALEURS EN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASS=CHANGEME_STRONG_PASSWORD_HERE
ADMIN_EMAIL=admin@your-domain.com

# AWS
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=eu-west-1
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET_NAME=your-bucket-name

# Ports
HTTP_PORT=8080
HTTPS_PORT=8443

# Environnement
NODE_ENV=production

# Grafana - ⚠️ CHANGEZ CES VALEURS EN PRODUCTION
GRAFANA_USER=admin
GRAFANA_PASS=CHANGEME_STRONG_PASSWORD_HERE
GRAFANA_PORT=3001
